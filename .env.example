# Pick any OpenAI-compatible provider/model. Examples:
#   OpenRouter:    LLM_BASE_URL=https://openrouter.ai/api/v1
#   NVIDIA build:  LLM_BASE_URL=https://integrate.api.nvidia.com/v1
#   OpenAI:        LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=anthropic/claude-3.5-sonnet

# Optional: override the sqlite db path (defaults to ./offerbench.db)
OFFERBENCH_DB_PATH=
